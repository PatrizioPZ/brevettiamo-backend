# BrevettIAmo Backend - Environment Variables
# Copia questo file in .env e inserisci le tue credenziali

# Server
PORT=3000
NODE_ENV=development

# Supabase (gia in uso nel frontend)
SUPABASE_URL=https://tuo-progetto.supabase.co
SUPABASE_KEY=tua-chiave-anon-supabase
SUPABASE_SERVICE_KEY=tua-chiave-service-role-supabase

# OpenRouter API (Alternativa a Kimi diretto - compatibile internazionale)
# Ottieni API key su https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-la-tua-chiave-openrouter
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=moonshot-ai/moonshot-v1-8k

# LemonSqueezy (per webhook)
LEMONSQUEEZY_API_KEY=your-lemon-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
API_RATE_LIMIT=100

# Frontend URL (per CORS e header OpenRouter)
FRONTEND_URL=https://patriziopz.github.io